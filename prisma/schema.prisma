  contactPerson          String?
  leadTime               Int?
  minimumOrderValue      Decimal?
  isActive               Boolean        @default(true)
  totalRatings           Int            @default(0)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

