  amount          Decimal
  dueDate         DateTime?
  status          String           @default("PENDING")
  createdBy       String
  createdByUser   User             @relation(fields: [createdBy], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("procurement_invoices")
}

model RFQ {
  id             String       @id @default(cuid())
