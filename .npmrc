# pnpm configuration for Vercel deployment

# Allow build scripts for native modules (Prisma, bcrypt, etc.)
# Required because pnpm 9 blocks lifecycle scripts by default
enable-pre-post-scripts=true

# Hoist node_modules for compatibility with Next.js and other tools
# that expect packages at the root level
shamefully-hoist=true

# Use a consistent store directory (Vercel caches this)
store-dir=/tmp/.pnpm-store
