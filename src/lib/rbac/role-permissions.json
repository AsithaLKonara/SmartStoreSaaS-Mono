{
  "rbac": {
    "version": "3.0",
    "model": "resource:action:scope"
  },
  "scopes": ["all", "tenant", "own", "assigned"],
  "permissions": {
    "products": [
      { "id": "products:read", "action": "read", "scope": "tenant" },
      { "id": "products:create", "action": "create", "scope": "tenant" },
      { "id": "products:update", "action": "update", "scope": "tenant" },
      { "id": "products:delete", "action": "delete", "scope": "tenant" }
    ],
    "orders": [
      { "id": "orders:read", "action": "read", "scope": "tenant" },
      { "id": "orders:create", "action": "create", "scope": "tenant" },
      { "id": "orders:update", "action": "update", "scope": "tenant" },
      { "id": "orders:delete", "action": "delete", "scope": "tenant" },
      { "id": "orders:fulfill", "action": "fulfill", "scope": "tenant" }
    ],
    "inventory": [
      { "id": "inventory:read", "action": "read", "scope": "tenant" },
      { "id": "inventory:update", "action": "update", "scope": "tenant" },
      { "id": "inventory:transfer", "action": "transfer", "scope": "tenant" }
    ],
    "customers": [
      { "id": "customers:read", "action": "read", "scope": "tenant" },
      { "id": "customers:create", "action": "create", "scope": "tenant" },
      { "id": "customers:update", "action": "update", "scope": "tenant" },
      { "id": "customers:delete", "action": "delete", "scope": "tenant" }
    ],
    "finance": [
      { "id": "finance:read", "action": "read", "scope": "tenant" },
      { "id": "finance:manage", "action": "manage", "scope": "tenant" },
      { "id": "payment:process", "action": "process", "scope": "tenant" }
    ],
    "pos": [
      { "id": "pos:terminal", "action": "terminal", "scope": "tenant" },
      { "id": "pos:payment", "action": "payment", "scope": "tenant" },
      { "id": "pos:refund", "action": "refund", "scope": "tenant" },
      { "id": "pos:discount", "action": "discount", "scope": "tenant" },
      { "id": "pos:shift", "action": "shift", "scope": "tenant" }
    ],
    "system": [
      { "id": "system:read", "action": "read", "scope": "all" },
      { "id": "system:manage", "action": "manage", "scope": "all" }
    ],
    "tenants": [
      { "id": "tenants:read", "action": "read", "scope": "all" },
      { "id": "tenants:create", "action": "create", "scope": "all" },
      { "id": "tenants:update", "action": "update", "scope": "all" },
      { "id": "tenants:delete", "action": "delete", "scope": "all" },
      { "id": "tenants:impersonate", "action": "impersonate", "scope": "all" }
    ],
    "users": [
      { "id": "user:view", "action": "read", "scope": "tenant" },
      { "id": "user:create", "action": "create", "scope": "tenant" },
      { "id": "user:update", "action": "update", "scope": "tenant" },
      { "id": "user:delete", "action": "delete", "scope": "tenant" }
    ],
    "roles": [
      { "id": "roles:read", "action": "read", "scope": "tenant" },
      { "id": "roles:manage", "action": "manage", "scope": "tenant" }
    ],
    "analytics": [
      { "id": "analytics:read", "action": "read", "scope": "tenant" }
    ],
    "settings": [
      { "id": "admin:settings", "action": "manage", "scope": "tenant" },
      { "id": "admin:integrations", "action": "manage", "scope": "tenant" },
      { "id": "admin:reports", "action": "manage", "scope": "tenant" }
    ],
    "support": [
      { "id": "support:read", "action": "read", "scope": "tenant" },
      { "id": "support:create", "action": "create", "scope": "tenant" },
      { "id": "support:manage", "action": "manage", "scope": "tenant" }
    ]
  },
  "roles": [
    {
      "id": "SUPER_ADMIN",
      "level": "platform",
      "description": "Platform administrator with full system control",
      "permissions": [
        "system:read", "system:manage",
        "tenants:read", "tenants:create", "tenants:update", "tenants:delete", "tenants:impersonate",
        "roles:read", "roles:manage"
      ]
    },
    {
      "id": "TENANT_ADMIN",
      "level": "tenant",
      "description": "Full organization administrator",
      "permissions": [
        "user:view", "user:create", "user:update", "user:delete",
        "roles:read", "roles:manage",
        "products:read", "products:create", "products:update", "products:delete",
        "orders:read", "orders:create", "orders:update", "orders:delete", "orders:fulfill",
        "customers:read", "customers:create", "customers:update", "customers:delete",
        "inventory:read", "inventory:update", "inventory:transfer",
        "shipping:manage", "returns:manage",
        "finance:read", "finance:manage", "payment:process",
        "pos:terminal", "pos:payment", "pos:refund", "pos:discount", "pos:shift",
        "analytics:read",
        "admin:settings", "admin:integrations", "admin:reports"
      ]
    },
    {
      "id": "SALES_STAFF",
      "level": "tenant",
      "permissions": [
        "products:read",
        "orders:read", "orders:create", "orders:update",
        "customers:read", "customers:create", "customers:update",
        "payment:process",
        "pos:terminal", "pos:payment", "pos:discount",
        "analytics:read"
      ]
    },
    {
      "id": "INVENTORY_MANAGER",
      "level": "tenant",
      "permissions": [
        "products:read", "products:create", "products:update",
        "inventory:read", "inventory:update", "inventory:transfer",
        "orders:read"
      ]
    },
    {
      "id": "ACCOUNTANT",
      "level": "tenant",
      "permissions": [
        "orders:read", "customers:read",
        "finance:read", "finance:manage", "payment:process",
        "admin:reports"
      ]
    },
    {
      "id": "CUSTOMER_SUPPORT",
      "level": "tenant",
      "permissions": [
        "customers:read", "customers:update",
        "orders:read", "orders:update",
        "support:read", "support:create", "support:manage"
      ]
    },
    {
      "id": "CUSTOMER",
      "level": "portal",
      "permissions": [
        "products:read",
        "orders:create"
      ]
    }
  ],
  "routePermissions": [
    {
      "route": "/dashboard/products",
      "permission": "products:read"
    },
    {
      "route": "/dashboard/products/create",
      "permission": "products:create"
    },
    {
      "route": "/dashboard/products/:id",
      "permission": "products:read"
    },
    {
      "route": "/dashboard/orders",
      "permission": "orders:read"
    },
    {
      "route": "/dashboard/orders/:id",
      "permission": "orders:read"
    },
    {
      "route": "/dashboard/inventory",
      "permission": "inventory:read"
    },
    {
      "route": "/dashboard/accounting",
      "permission": "finance:manage"
    },
    {
      "route": "/dashboard/settings",
      "permission": "admin:settings"
    },
    {
      "route": "/dashboard/analytics",
      "permission": "analytics:read"
    },
    {
      "route": "/pos/terminal",
      "permission": "pos:terminal"
    }
  ],
  "featureFlags": [
    "ai", "iot", "pos", "multi_tenant", "advanced_analytics"
  ]
}