    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "glob": "^13.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "prisma": "^6.16.2",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.1.2",
