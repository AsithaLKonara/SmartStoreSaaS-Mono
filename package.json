{
  "name": "smartstore-ai",
  "version": "1.0.0",
  "description": "AI-powered multi-channel commerce automation platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:docker": "NODE_ENV=production NEXT_TELEMETRY_DISABLED=1 PRISMA_CLIENT_ENGINE_TYPE=binary SKIP_ENV_VALIDATION=1 next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --config jest.integration.config.js",
    "test:api": "jest --testPathPattern=tests/integration/api",
    
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    
    "test:load": "k6 run tests/load/k6-load-test.js",
    "test:load:prod": "k6 run tests/load/k6-load-test.js --env BASE_URL=https://your-domain.com",
    "test:load:stress": "k6 run tests/load/k6-stress-test.js",
    
    "test:security": "jest --testPathPattern=tests/security --coverage",
    "test:security:zap": "docker run -v $(pwd):/zap/wrk/:rw -t owasp/zap2docker-stable zap-baseline.py -t http://localhost:3000 -J -j",
    "test:security:audit": "npm audit --audit-level=moderate",
    "test:security:fix": "npm audit fix",
    "test:security:ci": "npm audit --audit-level=high --json > test-results/security/security-report.json",
    "test:security:check-deps": "npx audit-ci --moderate",
    "test:security:scan": "npx snyk test",
    "test:security:monitor": "npx snyk monitor",
    
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:load && npm run test:security",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e:headless && npm run test:load && npm run test:security",
    
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:test:setup": "NODE_ENV=test prisma db push",
    "db:test:reset": "NODE_ENV=test prisma db push --force-reset",
    
    "lint:security": "npx eslint . --ext .ts,.tsx,.js,.jsx",
    "pre-commit": "npm run lint:security && npm run test:security:audit",
    
    "monolithic:setup": "./setup-monolithic.sh",
    "monolithic:start": "docker-compose up -d",
    "monolithic:stop": "docker-compose down",
    "monolithic:logs": "docker-compose logs -f",
    "monolithic:build": "docker-compose build --no-cache",
    "monolithic:restart": "docker-compose restart",
    "monolithic:status": "docker-compose ps"
  },
