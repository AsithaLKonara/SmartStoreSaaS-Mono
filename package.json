{
  "name": "smartstore-saas",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:custom-domain": "jest tests/custom-domain.test.ts --verbose",
    "test:custom-domain:coverage": "jest tests/custom-domain/ --coverage",
    "test:custom-domain:watch": "jest tests/custom-domain/ --watch",
    "test:db-integration": "jest --config jest.database-integration.config.js --verbose",
    "test:db-integration:backend": "jest --config jest.database-integration.config.js tests/database-integration/backend-crud-operations.test.ts --verbose",
    "test:db-integration:frontend": "jest --config jest.database-integration.config.js tests/database-integration/frontend-data-fetching.test.ts --verbose",
    "test:db-integration:workflows": "jest --config jest.database-integration.config.js tests/database-integration/crud-workflows.test.ts --verbose",
    "test:db-integration:consistency": "jest --config jest.database-integration.config.js tests/database-integration/data-consistency-transactions.test.ts --verbose",
    "test:db-integration:offline": "jest --config jest.database-integration.config.js tests/database-integration/offline-sync.test.ts --verbose",
    "test:db-integration:coverage": "jest --config jest.database-integration.config.js --coverage",
    "test:db-integration:watch": "jest --config jest.database-integration.config.js --watch",
    "test:deployment-comprehensive": "jest tests/comprehensive-deployment-test.ts --verbose",
    "test:deployment-all": "npm run test:custom-domain && npm run test:deployment-comprehensive && npm run test:db-integration",
    "seed:comprehensive": "ts-node prisma/seed-comprehensive.ts",
    "deploy:custom-domain": "./scripts/deploy-custom-domain.sh",
    "deploy:production": "vercel --prod",
    "deploy:preview": "vercel",
    "db:setup": "prisma generate && prisma db push",
    "db:setup:test": "prisma generate && prisma db push --schema=./prisma/schema.prisma",
    "db:seed": "prisma db seed",
    "db:seed:test": "prisma db seed --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset",
    "db:reset:test": "prisma migrate reset --schema=./prisma/schema.prisma",
    "db:check": "prisma db pull",
    "db:test:check": "prisma db pull --schema=./prisma/schema.prisma",
    "db:test:reset": "prisma migrate reset --schema=./prisma/schema.prisma",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@paypal/paypal-server-sdk": "^1.1.0",
    "@prisma/client": "6.16.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@woocommerce/woocommerce-rest-api": "^1.0.2",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.1.0",
    "googleapis": "^160.0.0",
    "ioredis": "^5.8.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.544.0",
    "next": "14.2.33",
    "next-auth": "^4.24.11",
    "next-themes": "^0.4.6",
    "nodemailer": "6.10.1",
    "openai": "^5.23.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.6.0",
    "shippo": "^2.15.0",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.3.1",
    "twilio": "^5.10.1",
    "xlsx-js-style": "^1.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.1.2",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.5.6",
    "prisma": "6.16.2",
    "puppeteer": "^24.22.3",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.1",
    "typescript": "^5",
    "vercel": "^48.1.6"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
