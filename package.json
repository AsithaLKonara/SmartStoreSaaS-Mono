{
  "name": "smartstore-saas",
  "version": "1.2.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:console": "eslint --ext .ts,.tsx --no-eslintrc --parser @typescript-eslint/parser --rule 'no-console: error' src/",
    "typecheck": "bash scripts/fetch-type-errors.sh",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:unit": "jest -c jest.config.unit.js --runInBand",
    "test:integration": "cross-env NODE_ENV=test jest -c jest.config.integration.js --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:local": "dotenv -e .env.test -- playwright test",
    "test:e2e:server": "E2E_BASE_URL=http://localhost:3000 playwright test --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test",
    "test:e2e:comprehensive": "playwright test tests/e2e/flows/comprehensive-browser-test.spec.ts",
    "test:e2e:comprehensive:headed": "playwright test tests/e2e/flows/comprehensive-browser-test.spec.ts --headed",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:coverage": "pnpm test:unit --coverage && pnpm test:integration --coverage",
    "test:correlation": "jest --testPathPattern=correlation",
    "test:report": "npx playwright show-report",
    "test:db": "npx tsx tests/database/validate-schema.ts",
    "test:comprehensive": "bash scripts/comprehensive-test-and-deploy.sh",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:test-users": "npx tsx scripts/seed-test-users.ts",
    "test:db:setup": "bash scripts/setup-test-db.sh",
    "test:db:reset": "dotenv -e .env.test -- prisma migrate reset --force --skip-seed",
    "db:test:setup": "dotenv -e .env.test -- prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:legacy": "npx tsx scripts/migrate-legacy-data.ts",
    "db:studio": "prisma studio",
    "audit:rbac": "npx tsx scripts/rbac-audit.ts",
    "postinstall": "prisma generate"
  },
