    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/stripe": "^8.0.416",
    "@types/uuid": "^9.0.8",
    "@types/woocommerce__woocommerce-rest-api": "^1.0.5",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
